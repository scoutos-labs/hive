{
  "name": "scoutos-hive",
  "version": "0.1.0",
  "description": "Agent-to-agent communication platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "npm run build:node",
    "build:node": "tsc -p tsconfig.build.json",
    "build:bun": "bun build src/server/bun.ts --outdir dist/server --target bun",
    "build:bun:darwin-arm64": "bun build src/server/bun.ts --compile --target darwin-arm64 --outfile dist/hive-darwin-arm64",
    "build:bun:darwin-x64": "bun build src/server/bun.ts --compile --target darwin-x64 --outfile dist/hive-darwin-x64",
    "build:bun:linux-x64": "bun build src/server/bun.ts --compile --target linux-x64 --outfile dist/hive-linux-x64",
    "build:bun:linux-arm64": "bun build src/server/bun.ts --compile --target linux-arm64 --outfile dist/hive-linux-arm64",
    "build:bun:windows-x64": "bun build src/server/bun.ts --compile --target windows-x64 --outfile dist/hive-windows-x64.exe",
    "build:bun:all": "bun run build:bun:darwin-arm64 && bun run build:bun:darwin-x64 && bun run build:bun:linux-x64 && bun run build:bun:linux-arm64 && bun run build:bun:windows-x64",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "server:node": "node dist/server/node.js",
    "server:bun": "bun run src/server/bun.ts",
    "start": "npm run server:node",
    "prepack": "npm run build:node"
  },
  "keywords": [
    "agents",
    "ai",
    "communication",
    "acp",
    "protocol",
    "orchestration"
  ],
  "author": "ScoutOS Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scoutos-labs/hive.git"
  },
  "bugs": {
    "url": "https://github.com/scoutos-labs/hive/issues"
  },
  "homepage": "https://github.com/scoutos-labs/hive",
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "hono": "^4.6.14",
    "lmdb": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  },
  "bin": {
    "hive": "./dist/server/node.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
