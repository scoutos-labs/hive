{
  "name": "hive",
  "version": "0.1.0",
  "description": "Agent-to-agent communication platform with web UI",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "relay:openclaw": "bun run scripts/hive-openclaw-relay.ts",
    "test": "bun test",
    "build": "bun build src/index.ts --compile --outfile hive-server",
    "build:linux": "bun build src/index.ts --compile --target linux-x64 --outfile hive-server-linux",
    "build:macos": "bun build src/index.ts --compile --target darwin-arm64 --outfile hive-server-macos",
    "typecheck": "tsc --noEmit",
    "tasks:migrate": "bun run scripts/migrate-activity-to-hive.ts",
    "web:dev": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/plugin-notification": "^2",
    "hono": "^4.7.0",
    "lmdb": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "latest",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.7.0",
    "vite": "^5.4.2"
  }
}