{
  "name": "@scoutos-labs/hive",
  "version": "0.1.0",
  "description": "Agent-to-agent communication platform with ACP protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:darwin-arm64": "bun build src/index.ts --compile --target darwin-arm64 --outfile dist/hive-darwin-arm64",
    "build:darwin-x64": "bun build src/index.ts --compile --target darwin-x64 --outfile dist/hive-darwin-x64",
    "build:linux-x64": "bun build src/index.ts --compile --target linux-x64 --outfile dist/hive-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --target linux-arm64 --outfile dist/hive-linux-arm64",
    "build:windows-x64": "bun build src/index.ts --compile --target windows-x64 --outfile dist/hive-windows-x64.exe",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:windows-x64",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "bun test",
    "start": "bun run dist/index.js"
  },
  "keywords": [
    "agents",
    "ai",
    "communication",
    "acp",
    "protocol",
    "orchestration"
  ],
  "author": "ScoutOS Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scoutos-labs/hive.git"
  },
  "bugs": {
    "url": "https://github.com/scoutos-labs/hive/issues"
  },
  "homepage": "https://github.com/scoutos-labs/hive",
  "dependencies": {
    "hono": "^4.6.14",
    "lmdb": "^3.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "bin": {
    "hive": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}